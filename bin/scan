#!/usr/bin/env python3
import argparse
import shutil
import subprocess
import sys
import tempfile
import termios
import tty
from pathlib import Path

DEVICE = "airscan:e0:Canon MF260 II Series"
DEST = Path("/home/ahal/Documents/Scanned")
SOURCES = ("Flatbed", "ADF", "ADF Duplex", "ADF Paged")


def wait_for_enter_or_esc():
    """Block until Enter (continue) or Esc (done). Returns True to continue, False to stop."""
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        while True:
            ch = sys.stdin.buffer.read(1)
            if ch in (b"\r", b"\n"):
                return True
            if ch == b"\x1b":
                return False
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def prompt(msg, value=None):
    if value:
        return value
    return input(f"{msg}: ").strip()


def main():
    parser = argparse.ArgumentParser(description="Scan documents to PDF.")
    parser.add_argument("-t", "--title", help="Document title (filename without .pdf)")
    parser.add_argument("-s", "--source", choices=SOURCES, help="Scanner source")
    parser.add_argument("-n", "--no-interactive", action="store_true", help="Skip confirmation prompt")
    args = parser.parse_args()

    if not DEST.is_dir():
        sys.exit(f"error: destination directory does not exist: {DEST}")

    title = prompt("Enter title", args.title)

    if args.source:
        scan_source = args.source
    else:
        for i, source in enumerate(SOURCES, 1):
            print(f"  {i}. {source}")
        choice = input("Enter source: ").strip()
        try:
            scan_source = SOURCES[int(choice) - 1]
        except (ValueError, IndexError):
            sys.exit(f"error: invalid choice '{choice}'")

    fname = f"{title}.pdf"
    dest_path = DEST / fname
    if dest_path.exists():
        sys.exit(f"error: destination file already exists: {dest_path}")

    print(f"Scanning to {dest_path} using {scan_source}")
    if not args.no_interactive:
        input("Press Enter to begin")

    with tempfile.TemporaryDirectory() as workdir:
        workdir = Path(workdir)
        if scan_source == "ADF Paged":
            page_num = 1
            while True:
                result = subprocess.run(
                    [
                        "scanimage",
                        f"--device-name={DEVICE}",
                        "--format", "tiff",
                        "--batch=out%04d.tif",
                        "--batch-count=1",
                        f"--batch-start={page_num}",
                        "--source=ADF",
                        "--resolution", "150",
                    ],
                    cwd=workdir,
                )
                if result.returncode != 0:
                    sys.exit(f"error: scan failed on page {page_num}")
                print(f"Page {page_num} scanned.  [Enter] next page  [Esc] save and exit")
                if not wait_for_enter_or_esc():
                    break
                page_num += 1
        else:
            subprocess.run(
                [
                    "scanimage",
                    f"--device-name={DEVICE}",
                    "--format", "tiff",
                    "--batch",
                    f"--source={scan_source}",
                    "--resolution", "150",
                ],
                cwd=workdir,
            )
        tifs = sorted(workdir.glob("*.tif"))
        if not tifs:
            sys.exit(
                "error: no pages scanned\n"
                "  - check the scanner is powered on and reachable at 192.168.88.246\n"
                "  - ensure documents are loaded in the ADF\n"
                "  - try --source Flatbed to test basic connectivity"
            )
        subprocess.run(["magick", *tifs, workdir / fname], check=True)
        shutil.move(workdir / fname, dest_path)


if __name__ == "__main__":
    main()
