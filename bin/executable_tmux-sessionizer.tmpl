#!/usr/bin/env bash

setup_layout() {
    local session=$1
    local dir=$2
    # tmux percentage sizing is broken on Ubuntu, requiring a smaller value to get ~40% visually
    tmux split-window -t $session:0.0 -h -c "$dir"
    tmux resize-pane -t $session:0.1 -x {{ if eq .chezmoi.osRelease.id "ubuntu" }}10%{{ else }}40%{{ end }}
    tmux split-window -t $session:0.1 -v -c "$dir"
    tmux send-keys -t $session:0.1 'claude' Enter
    tmux select-pane -t $session:0.0
    tmux send-keys -t $session:0.0 'nvim' Enter
}

if [[ $# -eq 1 ]]; then
    root_dir=~
    selected=$1
else
    root_dir=~/dev
    selected=$(find $root_dir/ -mindepth 1 -maxdepth 1 -type d | xargs -L1 -I{} basename "{}" | sort | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

tmux_running=$(pgrep tmux)
selected_root=$root_dir/$selected

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -ds $selected -c $selected_root
    setup_layout $selected $selected_root
    tmux attach-session -t $selected
    #base16_chalk
    exit 0
fi

if ! tmux has-session -t=$selected 2> /dev/null; then
    tmux new-session -ds $selected -c $selected_root
    setup_layout $selected $selected_root
fi

tmux switch-client -t $selected
#base16_chalk
