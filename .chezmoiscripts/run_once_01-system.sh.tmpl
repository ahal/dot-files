#!/bin/bash
set -euo pipefail

mkdir -p "$HOME/bin"

{{ if eq .chezmoi.osRelease.id "fedora" -}}
sudo dnf install -y \
  ddcutil \
  libxcb-devel \
{{ if not .enable_mozilla -}}
  mangohud \
{{ end -}}
  meld \
  python3-devel \
  tmux \
  zsh
{{ else if eq .chezmoi.osRelease.id "ubuntu" -}}
sudo apt-get install -y \
  ddcutil \
  libxcb1-dev \
  libxcb-render0-dev \
  libxcb-shape0-dev \
  libxcb-xfixes0-dev \
{{ if not .enable_mozilla -}}
  mangohud \
{{ end -}}
  meld \
  tmux \
  zsh
{{ end -}}

# tmux plugin manager
if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
  git clone --branch master https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
fi
