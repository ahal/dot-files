#!/usr/bin/env python3
import subprocess
import sys
import tempfile
from datetime import date as Date
from pathlib import Path

DEVICE = "airscan:e1:Canon MF260 II Series"
DEST = Path("/home/ahal/Documents/Scanned Documents")
SOURCES = ("Flatbed", "ADF", "ADF Duplex")


def prompt(msg, value=None):
    if value:
        return value
    return input(f"{msg}: ").strip()


def main():
    if not DEST.is_dir():
        sys.exit(f"error: destination directory does not exist: {DEST}")

    args = sys.argv[1:]
    correspondant = prompt("Enter correspondant", args[0] if len(args) > 0 else None)

    if len(args) > 1:
        scan_source = args[1]
        if scan_source not in SOURCES:
            sys.exit(f"error: unknown source '{scan_source}', must be one of: {', '.join(SOURCES)}")
    else:
        for i, source in enumerate(SOURCES, 1):
            print(f"  {i}. {source}")
        choice = input("Enter source: ").strip()
        try:
            scan_source = SOURCES[int(choice) - 1]
        except (ValueError, IndexError):
            sys.exit(f"error: invalid choice '{choice}'")

    date_str = prompt("Enter date (YYYY-MM-DD)", args[2] if len(args) > 2 else str(Date.today()))
    try:
        Date.fromisoformat(date_str)
    except ValueError:
        sys.exit(f"error: invalid date '{date_str}', expected YYYY-MM-DD")

    fname = f"{date_str}-{correspondant}.pdf"
    dest_path = DEST / fname
    if dest_path.exists():
        sys.exit(f"error: destination file already exists: {dest_path}")

    print(f"Scanning to {dest_path} using {scan_source}")
    input("Press Enter to begin")

    with tempfile.TemporaryDirectory() as workdir:
        workdir = Path(workdir)
        subprocess.run(
            [
                "scanimage",
                f"--device-name={DEVICE}",
                "--format", "tiff",
                "--batch",
                f"--source={scan_source}",
                "--resolution", "150",
            ],
            cwd=workdir,
            check=True,
        )
        tifs = sorted(workdir.glob("*.tif"))
        if not tifs:
            sys.exit("error: no pages scanned")
        subprocess.run(["convert", *tifs, workdir / fname], check=True)
        (workdir / fname).rename(dest_path)


if __name__ == "__main__":
    main()
